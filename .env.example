# העתק ל-.env ומלא ערכים
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# WhatsApp Cloud API (Meta) — https://developers.facebook.com/docs/whatsapp/cloud-api
# WHATSAPP_ACCESS_TOKEN=EAAG...
# WHATSAPP_PHONE_NUMBER_ID=123456789012345
# מספר יעד בינלאומי בלי + (למשל ישראל: 972501234567)
# ה-API הרשמי שולח למספר בודד, לא ישירות לקבוצה — ראה README או ההסבר בצ'אט
# WHATSAPP_RECIPIENT=972501234567
# שליחה אוטומטית כשמגיע וידאו לבוט טלגרם (true/false)
# WHATSAPP_AUTO_SEND=true
